# Export Desi Website v2 - Environment Variables Example
# Copy this file to .env and fill in your actual values

# Formspree form endpoint
# Get your form ID at https://formspree.io/dashboard
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Google reCAPTCHA v2 site key
# Get your keys at https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Microsoft Clarity project ID (optional, for session recording)
# Get your project ID at https://clarity.microsoft.com
VITE_CLARITY_PROJECT_ID=your_clarity_project_id

# Google Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
