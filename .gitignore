# =============================================================================
# WEBSITE V2 (exportdesi.com) - .gitignore
# =============================================================================
# React 19 + Vite + Tailwind CSS

# =============================================================================
# SECRETS - NEVER COMMIT
# =============================================================================
.env
.env.local
.env.*.local
.env.production

# =============================================================================
# DEPENDENCIES
# =============================================================================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# =============================================================================
# BUILD OUTPUT
# =============================================================================
dist/
dist-ssr/
build/
*.local

# =============================================================================
# VITE
# =============================================================================
.vite/

# =============================================================================
# LOGS & OUTPUTS
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*-output.txt
.backup/

# =============================================================================
# EDITOR
# =============================================================================
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =============================================================================
# TESTING (if added later)
# =============================================================================
/coverage

# =============================================================================
# VERCEL DEPLOYMENT
# =============================================================================
.vercel

.vercel
